// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Hakikisha provider ni sahihi na aina ya database yako (Mfano: "postgresql" au "mysql")
datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String?
  email     String     @unique
  password  String?
  phone     String?
  role      String     @default("USER") // Inaweza kuwa "ADMIN" au "USER"
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  orders    Order[]
  cartItems CartItem[]
}

model Product {
  id             String      @id @default(cuid())
  sku            String      @unique
  name           String
  category       String
  brand          String?
  
  // === MABORESHO MPYA KWA AJILI YA HOME PAGE ===
  badge          String?     @default("")
  condition      String?     @default("Brand New")
  
  description    String?     @db.Text
  buyingPrice    Float       @default(0)
  price          Float
  stockQuantity  Int         @default(0)
  specifications String?     @db.Text // Inahifadhi JSON string ya features
  imageUrl       String?
  imageEmoji     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Mahusiano na meza nyingine
  cartItems      CartItem[]
  orderItems     OrderItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String?  // Ikiwa null inamaanisha mteja anatumia Session/hajalogin
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // === SULUHISHO LA KUFUTA BIDHAA (Cascade Delete) ===
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  totalAmount     Float
  shippingAddress String?     @db.Text
  shippingMethod  String?
  paymentType     String?
  paymentMethod   String?
  status          String      @default("PENDING") // PENDING, COMPLETED, CANCELLED
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float    // Bei ya bidhaa wakati inanunuliwa
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // === SULUHISHO LA KUFUTA BIDHAA (Cascade Delete) ===
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}