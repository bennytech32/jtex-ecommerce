// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. MTEJA / MUUZAJI (USERS)
model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  phone         String?
  password      String
  role          String         @default("CUSTOMER") // CUSTOMER, VENDOR, ADMIN, SUPER_ADMIN
  loyaltyPoints Int            @default(0)
  debtAmount    Float          @default(0.0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  orders        Order[]
  vendorProfile VendorProfile?
}

// 2. DUKA LA MUUZAJI KAMA NI MARKETPLACE
model VendorProfile {
  id          String   @id @default(uuid())
  storeName   String
  description String?
  address     String?
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
}

// 3. BIDHAA (PRODUCTS)
model Product {
  id             String      @id @default(uuid())
  sku            String      @unique
  name           String
  description    String
  category       String
  brand          String?
  buyingPrice    Float       @default(0.0) // Bei ya kununulia (Ghalani)
  price          Float       // Bei ya kuuzia (Dukani)
  oldPrice       Float?      // Bei ya zamani (Ili kuonyesha punguzo)
  stockQuantity  Int         @default(0)
  inStock        Boolean     @default(true)
  lowStockAlert  Int         @default(5)
  imageUrl       String?
  imageEmoji     String      @default("📦")
  specifications String?     // Mfano: RAM 8GB, ROM 256GB
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  orderItems     OrderItem[]
}

// 4. ODA & USAFIRISHAJI (ORDERS)
model Order {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  items          OrderItem[]
  totalAmount    Float
  shippingFee    Float       @default(0.0)
  upfrontPayment Float       @default(0.0) // Kianzio alicholipa (Mfano 20%)
  deliveryRegion String      // Mfano: Dar es Salaam, Mwanza
  address        String
  paymentMethod  String      @default("COD") // Cash On Delivery
  status         String      @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// 5. BIDHAA NDANI YA ODA (ORDER ITEMS)
model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  subTotal  Float
}

// 6. FEDHA NA MIAMALA (FINANCE TRANSACTIONS)
model FinanceTransaction {
  id          String   @id @default(uuid())
  type        String   // INCOME au EXPENSE
  category    String   // Mfano: Rent, Salary, Sales
  amount      Float
  description String?
  date        DateTime @default(now())
}