// ====================================================================
// JTEX E-COMMERCE - PRISMA SCHEMA
// ====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================================================================
// 1. PRODUCTS & INVENTORY MODELS
// ====================================================================

model Product {
  id              String      @id @default(uuid())
  sku             String      @unique
  name            String
  category        String      // Jina la kategoria
  brand           String?
  model           String?
  badge           String?     // Mfano: Hot, Sale, Pre-Order
  condition       String?     @default("Brand New")
  buyingPrice     Float?      // Bei ya kununulia (Admin only)
  price           Float       // Bei ya kuuzia (Public)
  stockQuantity   Int         @default(0)
  
  // Taarifa za ziada zilizohifadhiwa kama JSON String
  specifications  String?     @db.Text // Huhifadhi rangi, RAM, n.k.
  preOrderInfo    String?     @db.Text // Huhifadhi taarifa za Dubai/China & Freight
  imageUrl        String?     @db.Text // Array ya link za Cloudinary
  
  // Relations
  orderItems      OrderItem[] // Inaunganisha bidhaa na oda za wateja

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model SpecTemplate {
  id        String   @id @default(uuid())
  title     String
  fields    String[] // Array ya strings (PostgreSQL inasupport hii moja kwa moja)
  createdAt DateTime @default(now())
}

// ====================================================================
// 2. USERS & AUTHENTICATION MODELS
// ====================================================================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hashed password
  phone     String?
  role      Role     @default(CUSTOMER) // Admin au Mteja
  
  orders    Order[]  // Oda zilizofanywa na mteja huyu

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  CUSTOMER
  ADMIN
}

// ====================================================================
// 3. ORDERS & TRANSACTIONS MODELS
// ====================================================================

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique // Mfano: ORD-2026-001
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  
  status        OrderStatus @default(PENDING)
  totalAmount   Float
  shippingInfo  String?     @db.Text // Jina, Anwani, Namba ya simu ya mteja (JSON)
  
  items         OrderItem[] // Bidhaa zilizo ndani ya hii oda

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  quantity    Int
  priceAtTime Float    // Bei iliyotumika wakati oda inafanywa
  colorOption String?  // Kama mteja alichagua rangi maalum (Multi-color support)
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}